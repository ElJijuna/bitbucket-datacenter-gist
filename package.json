{
    "name": "bitbucket-datacenter-gist",
    "version": "0.2.0",
    "description": "GitHub Gist-like application for Bitbucket Data Center",
    "type": "module",
    "main": "src/index.js",
    "scripts": {
        "start": "bun src/api/server.js",
        "dev": "bun --watch src/api/server.js",
        "test": "bun test",
        "test:watch": "bun test --watch",
        "test:coverage": "bun test --coverage",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "ui:dev": "MOCK=false vite --config vite.config.js",
        "ui:dev:mock": "vite --config vite.config.js",
        "ui:build": "vite build --config vite.config.js",
        "ui:routes": "intent generate --config vite.config.js"
    },
    "keywords": [
        "bitbucket",
        "gist",
        "datacenter",
        "bun",
        "api"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@gnome-ui/charts": "^1.28.0",
        "@gnome-ui/core": "^1.41.0",
        "@gnome-ui/hooks": "^1.27.0",
        "@gnome-ui/layout": "^1.13.0",
        "@gnome-ui/react": "^1.38.0",
        "@tanstack/react-router": "^1.168.23",
        "dotenv": "^16.3.1",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "react": "19",
        "react-dom": "19",
        "simple-git": "^3.22.0"
    },
    "devDependencies": {
        "@tanstack/intent": "^0.0.29",
        "@tanstack/router-plugin": "^1.167.22",
        "@vitejs/plugin-react": "^4.0.0",
        "bun-types": "latest",
        "eslint": "^8.52.0",
        "jest": "30",
        "vite": "^8.0.0"
    },
    "engines": {
        "bun": ">=1.0.0"
    }
}