# Bitbucket Server connection
BITBUCKET_SERVER_HOST=https://bitbucket.example.com
BITBUCKET_API_HOST=https://bitbucket.example.com/rest/api/1.0
BITBUCKET_USER=your-username
BITBUCKET_TOKEN=your-api-token

# SSH port for cloning repos (Bitbucket DC default: 7999)
BITBUCKET_SSH_PORT=7999

# Whitelist of PROJECT:repo pairs allowed to be managed
# Format: PROJECT:repo (colon-separated), multiple entries comma-separated
# If empty or not set, all requests return 403
ALLOWED_REPOS=MYPROJECT:repo1,MYPROJECT:repo2,TOOLS:repotools

# Git performance tuning
GIT_PULL_INTERVAL=30   # seconds between pulls per repo (default: 30)
GIT_PUSH_DEBOUNCE=500  # ms to wait before pushing, coalesces rapid writes (default: 500)

# Git commit author (optional - defaults to BITBUCKET_USER)
# GIT_USER_NAME=Your Name
# GIT_USER_EMAIL=your-email@company.com

# For /api/repository/* routes (optional)
# BITBUCKET_PROJECT=MYPROJECT
# BITBUCKET_REPOSITORY=repo1

# Application
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
